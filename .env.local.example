# Convex (from `npx convex dev`; Convex static hosting injects the production value during deploy)
VITE_CONVEX_URL=https://your-deployment.convex.cloud

# Optional: Clerk (recommended for production). If unset, use Convex env SPARKLER_DEMO_OWNER_SUBJECT for dev-only uploads.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Optional: public origin of the built app (defaults to window.location.origin). Used by /cli-login help text.
# VITE_SPARKLER_PUBLIC_URL=https://your-app.convex.site

# CLI vars can now live in .env / .env.local in the repo root; the CLI auto-loads them.
# Clerk path: sparkler login
# SPARKLER_CONVEX_URL=https://your-deployment.convex.cloud
# SPARKLER_DEPLOYMENT_URL=https://your-app.convex.site   # or http://localhost:5173
# Optional custom env file path when invoking the CLI:
# SPARKLER_ENV_FILE=/absolute/path/to/sparkler.env
# Demo path (no Clerk): set Convex SPARKLER_DEMO_OWNER_SUBJECT, then either:
# SPARKLER_DEMO=1
# or pass --demo to sparkler host/list/del
# HTTP path (CI / bots): sparkler host with bearer
# SPARKLER_CONVEX_SITE_URL=https://your-deployment.convex.site
# SPARKLER_CLI_TOKEN=same-as-SPARKLER_CLI_SECRET-in-Convex-dashboard
