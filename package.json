{
  "name": "sparkler-workspace",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "convex:dev": "convex dev",
    "convex:deploy": "convex deploy",
    "deploy:site": "npx @convex-dev/static-hosting upload --build --dev",
    "deploy:site:prod": "npx @convex-dev/static-hosting upload --build --prod",
    "deploy:all:prod": "npx @convex-dev/static-hosting deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.758.0",
    "@aws-sdk/s3-request-presigner": "^3.758.0",
    "@clerk/clerk-react": "^5.22.0",
    "@convex-dev/static-hosting": "^0.1.3",
    "@sparkjsdev/spark": "file:./vendor/spark",
    "convex": "^1.17.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.1.1",
    "three": "^0.180.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.11"
  }
}
